# =============================================================================
# MarzbanBot — Environment Configuration
# Copy this file to `.env` and fill in your values.
# =============================================================================


# -----------------------------------------------------------------------------
# Telegram API & Bot
# Get API_ID and API_HASH from https://my.telegram.org/apps
# Get BOT_TOKEN from @BotFather
# -----------------------------------------------------------------------------
API_ID=11111111111
API_HASH=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
BOT_TOKEN=2222222222:XXXXXXXXXXXXXXXXXXXXXXXX


# -----------------------------------------------------------------------------
# Admins & Branding
# -----------------------------------------------------------------------------
# Comma-separated Telegram user IDs with admin access
ADMIN_ID=3333333333333,4444444444444

# Username shown in the bot (without @)
# BOT_TAG=EsiDambarikBot
# ADMIN_ID_TAG=EsiDambarik
# CHANNEL_ID_TAG=EsiDambarik

# Inline tutorial/help button links (comma-separated URLs; leave empty to hide)
# TUTORIAL_HELP_LINKS=

# Uptime status button
# DISABLE_UPTIME_BUTTONS=true
# LINK_UPTIME_BUTTONS=https://status.google.ir


# -----------------------------------------------------------------------------
# Log Channel
# Telegram channel/group ID for operational logs (payments, purchases, errors, …)
# Leave empty or comment out to disable Telegram log delivery entirely.
# LOG_CHANNEL=-1001772624536


# -----------------------------------------------------------------------------
# Database
# Supported drivers: mysql+asyncmy, postgresql+asyncpg, sqlite+aiosqlite
# Docker install: SQLALCHEMY_DATABASE_URL and MARIADB_* below are set by scripts/pasarguardbot.sh
# Native install: uses 127.0.0.1:6162 (MariaDB) and 127.0.0.1:6161 (Redis) — isolated from system DB ports
# -----------------------------------------------------------------------------
SQLALCHEMY_DATABASE_URL=mysql+asyncmy://pasarguardbot:PASSWORD@localhost:3306/pasarguardbot
# SQLALCHEMY_DATABASE_URL=sqlite+aiosqlite:///./pasarguard.db

# -----------------------------------------------------------------------------
# FastAPI & Webhooks
# -----------------------------------------------------------------------------
# Leave empty or comment out to disable the FastAPI server
FASTAPI_PORT=6160

# Shared secret for incoming webhook requests
WEBHOOK_SECRET=kenzo


# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Key used to encrypt stored passwords and sensitive data
CRYPTO_KEY=KENZO


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# LOG_LEVEL=INFO
# LOG_DIR=./logs
# LOG_TO_FILE=true
# LOG_USE_RICH=false

# Standard Python logging format string
# LOG_FORMAT=%(asctime)s | %(levelname)-8s | %(message)s
# Verbose format with file and line number:
# LOG_FORMAT=%(asctime)s | %(levelname)-8s | %(name)s | %(filename)s:%(lineno)d | %(message)s

# LOG_MIDDLEWARE_DEBUG=false
# LOG_HANDLER_EVENTS=false

# Log rotation (optional — defaults shown)
# LOG_APP_MAX_BYTES=5242880
# LOG_APP_BACKUP_COUNT=5
# LOG_ERROR_MAX_BYTES=2097152
# LOG_ERROR_BACKUP_COUNT=3


# -----------------------------------------------------------------------------
# Integrations
# -----------------------------------------------------------------------------
# Optional GitHub personal access token for help-download release lookups.
# Public repos work without it; set this to raise API rate limits or access private repos.
# GITHUB_TOKEN=


# -----------------------------------------------------------------------------
# Crypto Payment Networks
# -----------------------------------------------------------------------------
# TRON (TRX): leave empty for mainnet
# Supported testnets: nile, shasta
# TRX_TESTNET_MODE=

# TON: leave empty for mainnet; set to "testnet" for TON Testnet
# TON_TESTNET_MODE=


# -----------------------------------------------------------------------------
# Optional — Infrastructure
# -----------------------------------------------------------------------------
# Redis connection URL (conversation state, locks, callback payloads)
# REDIS_URL=redis://localhost:6161
# Namespace prefix when multiple bots share one Redis (e.g. pasarguard:mainbot)
# REDIS_NAMESPACE_PREFIX=pasarguardbot:mainbot
# TTL defaults in seconds (optional)
# STATE_TTL_SECONDS=86400
# LOCK_TTL_SECONDS=300
# CALLBACK_TTL_SECONDS=3600

# Comma-separated Telegram module paths to disable at startup
# DISABLED_TELEGRAM_MODULES=

# Telethon session file path (relative to project root; use sessions/KenzoSession in Docker)
# TELETHON_SESSION_PATH=KenzoSession

# -----------------------------------------------------------------------------
# MariaDB container (Docker only — appended by installer)
# -----------------------------------------------------------------------------
# MARIADB_ROOT_PASSWORD=
# MARIADB_DATABASE=pasarguardbot
# MARIADB_USER=pasarguardbot
# MARIADB_PASSWORD=

# -----------------------------------------------------------------------------
# Docker deploy paths (set by installer)
# -----------------------------------------------------------------------------
# PASARGUARDBOT_CONFIG_DIR=/opt/pasarguardbot
